{
  "include": [
    "env.d.ts",
    "src/**/*",
    "src/**/*.vue",
    "src/**/*.ts",
    "src/**/*.json"
  ],
  "exclude": ["src/**/__tests__/*"],
  "compilerOptions": {
    "composite": true,

    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "node",

    "lib": ["ESNext", "DOM"],
    "types": [],

    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },

    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "esModuleInterop": true,

    "useDefineForClassFields": true,
    "isolatedModules": true
  }
}